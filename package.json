{
  "name": "paste-markdown-link",
  "publisher": "tomchen",
  "author": "Tom Chen <tomchen.org@gmail.com>",
  "displayName": "Paste Markdown Link",
  "description": "Paste URL as formatted Markdown link when text is selected",
  "version": "1.2.1",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "categories": [
    "Programming Languages",
    "Formatters",
    "Other"
  ],
  "keywords": [
    "markdown",
    "link",
    "paste",
    "url",
    "syntax",
    "format",
    "copy",
    "clipboard",
    "image"
  ],
  "bugs": {
    "url": "https://github.com/tomchen/vscode-paste-markdown-link/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tomchen/vscode-paste-markdown-link"
  },
  "license": "MIT",
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "paste-markdown-link.paste",
        "title": "Paste Markdown Link (Ctrl+V)"
      },
      {
        "command": "paste-markdown-link.paste-nocheck",
        "title": "Paste Markdown Link"
      },
      {
        "command": "paste-markdown-link.paste-img",
        "title": "Paste Markdown Image"
      }
    ],
    "keybindings": [
      {
        "command": "paste-markdown-link.paste",
        "key": "ctrl+v",
        "mac": "cmd+v",
        "when": "editorTextFocus && editorLangId =~ /^markdown$|^mdx$|^rmd$|^quarto$/ && editorHasSelection"
      }
    ]
  },
  "activationEvents": [
    "onLanguage:markdown",
    "onLanguage:mdx",
    "onLanguage:rmd",
    "onLanguage:quarto"
  ],
  "scripts": {
    "vscode:prepublish": "bun run compile:prod",
    "compile": "bun run check-types && bun run lint && node esbuild.js",
    "compile:prod": "bun run check-types && bun run lint && node esbuild.js --production",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "bun run compile-tests && bun run compile && bun run lint",
    "checkall": "bun run check-types && bun run lint && bun run format",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test": "vscode-test",
    "vsix": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "25.5.0",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  }
}
